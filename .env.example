# InsightPulse Secret Keys
# Rename this file to .env and put your real keys here.
# DO NOT COMMIT YOUR REAL .env FILE TO GITHUB!

# OpenAI: get yours at https://platform.openai.com/
OPENAI_API_KEY=your_openai_key_here

# Anthropic: get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_key_here

# Google Gemini: get yours at https://aistudio.google.com/
GOOGLE_API_KEY=your_google_key_here

# Any other LiteLLM supported keys can be added here.
